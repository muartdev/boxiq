{
  "expo": {
    "name": "Boxiq",
    "slug": "boxiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "boxiq",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#F5F0E8",
    "splash": {
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
